{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "时窗",
  "version": "1.0.0",
  "identifier": "com.edesign.screen-time",
  "build": {
    "beforeDevCommand": "node ./scripts/tauri-dev.mjs",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node ./scripts/tauri-build.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "时窗",
        "width": 900,
        "height": 640,
        "minWidth": 900,
        "maxWidth": 900,
        "minHeight": 640,
        "maxHeight": 640,
        "resizable": false,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese", "English"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "bundleName": "时窗"
    }
  }
}
